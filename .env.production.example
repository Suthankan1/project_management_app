# Copy to .env.production on the EC2 host and replace every placeholder.
# Do not commit .env.production.

# --- EC2 CONTAINER SETTINGS ---
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS=-XX:MaxRAMPercentage=75 -XX:+ExitOnOutOfMemoryError

# --- MANAGED POSTGRES ---
SPRING_DATASOURCE_URL=jdbc:postgresql://your-managed-postgres-host:5432/planora?sslmode=require
SPRING_DATASOURCE_USERNAME=your_production_db_user
SPRING_DATASOURCE_PASSWORD=your_production_db_password
DB_POOL_MAX_SIZE=12
DB_POOL_MIN_IDLE=2

# --- LOCAL REDIS CONTAINER ---
REDIS_PORT=6379
REDIS_CONNECT_TIMEOUT=500ms
REDIS_TIMEOUT=500ms
REDIS_LETTUCE_SHUTDOWN_TIMEOUT=100ms
APP_CACHE_REDIS_ENABLED=true
APP_CACHE_REDIS_FAIL_OPEN=true
NOTIFICATIONS_CACHE_REDIS_ENABLED=true

# --- DATABASE MIGRATIONS ---
FLYWAY_ENABLED=true
FLYWAY_VALIDATE_ON_MIGRATE=true
JPA_DDL_AUTO=validate
APP_FLYWAY_REPAIR_ON_STARTUP=false

# --- AUTH AND COOKIES ---
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_base64_jwt_secret
APP_COOKIE_SECURE=true
APP_COOKIE_SAMESITE=None

# --- NETLIFY / BROWSER ORIGINS ---
# Example: https://your-site.netlify.app,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://your-netlify-site.netlify.app
# Browser origins allowed to open WebSocket connections to the backend.
WEBSOCKET_ALLOWED_ORIGINS=https://your-netlify-site.netlify.app
# Public frontend origin used in outbound emails such as project invitation links.
APP_FRONTEND_BASE_URL=https://planora-pma.netlify.app

# --- MAIL SERVER ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_sender@example.com
MAIL_PASSWORD=your_smtp_app_password

# --- AWS S3 STORAGE ---
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_REGION=eu-north-1
AWS_PROFILE_PHOTOS_BUCKET=your-production-profile-photos-bucket
AWS_DMS_BUCKET=your-production-document-storage-bucket
AWS_CHAT_BUCKET=your-production-chat-attachments-bucket
AWS_TASK_STORAGE_BUCKET=your-production-task-attachments-bucket

# --- GITHUB INTEGRATION ---
GITHUB_DEFAULT_TOKEN=
# Generate with: openssl rand -base64 32
GITHUB_TOKEN_ENCRYPTION_KEY=replace_with_base64_32_byte_key
GITHUB_WEBHOOK_SECRET=replace_with_github_webhook_secret
GITHUB_SYNC_ENABLED=true
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_MOBILE_CLIENT_ID=
GITHUB_MOBILE_CLIENT_SECRET=
GITHUB_MOBILE_REDIRECT_URI=mobile://github-callback
