# --- DATABASE CONFIG (Optional overrides if using external DB) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/planora_db
SPRING_DATASOURCE_USERNAME=planora
SPRING_DATASOURCE_PASSWORD=change_me_local_db_password
POSTGRES_DB=planora_db
POSTGRES_USER=planora
POSTGRES_PASSWORD=change_me_local_db_password
# WARNING: NEVER enable ignoring missing migrations (e.g. *:missing) in production environments
# as it allows silent data schema drift and missing migration errors to go unnoticed.
# FLYWAY_IGNORE_MIGRATION_PATTERNS=*:missing

# --- AUTH SECRETS ---
JWT_SECRET=your_jwt_secret_here

# --- MAIL SERVER CONFIG ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# --- GITHUB TOKEN ENCRYPTION ---
# AES-256 key for encrypting GitHub access tokens at rest.
# Must be a Base64-encoded 32-byte (256-bit) random value.
# Generate with: openssl rand -base64 32
# IMPORTANT: Changing this key invalidates all stored tokens — users must reconnect GitHub.
GITHUB_TOKEN_ENCRYPTION_KEY=your_base64_encoded_32_byte_key_here

# --- AWS S3 STORAGE CONFIG (MANDATORY) ---
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_REGION=eu-north-1
AWS_S3_PROFILE_BUCKET=local-planora-profile-bucket
AWS_S3_DMS_BUCKET=local-planora-dms-bucket
AWS_S3_CHAT_BUCKET=local-planora-chat-bucket
AWS_S3_TASK_BUCKET=local-planora-task-bucket
