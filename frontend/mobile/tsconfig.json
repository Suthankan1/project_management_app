{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-native",
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@/src/*": ["./src/*"],
      "@api-contracts/*": ["../api-contracts/*"],
      "@planora/contracts": ["../api-contracts/index.ts"],
      "@planora/contracts/*": ["../api-contracts/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../api-contracts/**/*.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
